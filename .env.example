# ─── Tidal API ───────────────────────────────────────────
# 발급: https://developer.tidal.com/dashboard
# Cloudflare Tunnel: mrms.approid.team → localhost:8080
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_REDIRECT_URI=https://mrms.approid.team/callback/tidal

# Tidal scopes (space-separated)
# 읽기:
# - user.read         : 계정 정보 (국가, 이메일)
# - collection.read   : My Collection (저장 트랙)
# - playlists.read    : 본인 플레이리스트 조회
# - search.read       : 개인화 검색
# 쓰기:
# - collection.write  : My Collection에 트랙/앨범 추가·제거
# - playlists.write   : 플레이리스트 생성·수정·삭제 (추천 결과 저장용 ★)
# - search.write      : 검색 이력 수정/삭제
# 재생:
# - playback          : 재생 + 제어
TIDAL_SCOPES="user.read collection.read collection.write playlists.read playlists.write search.read search.write playback"

# ─── Spotify API ─────────────────────────────────────────
# 발급: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://mrms.approid.team/callback/spotify

# Spotify scopes (space-separated)
# 읽기 — 계정 / 라이브러리:
# - user-read-email                  : 이메일
# - user-read-private                : 국가, Premium 여부
# - user-library-read                : 저장 트랙/앨범
# - playlist-read-private            : 비공개 플레이리스트
# - playlist-read-collaborative      : 협업 플레이리스트
# 읽기 — 청취 신호 (학습용 ★):
# - user-read-recently-played        : 최근 청취 (skip/repeat 감지)
# - user-top-read                    : Top 트랙/아티스트
# 쓰기:
# - user-library-modify              : 라이브러리 트랙 추가/제거
# - playlist-modify-private          : 비공개 플레이리스트 수정
# - playlist-modify-public           : 공개 플레이리스트 수정 (추천 결과 저장 ★)
# 재생:
# - user-read-currently-playing      : 현재 곡
# - user-read-playback-state         : 재생 상태
# - user-modify-playback-state       : 재생 제어
# - streaming                        : Web Playback SDK (Premium 필수)
SPOTIFY_SCOPES="user-read-email user-read-private user-library-read user-library-modify playlist-read-private playlist-read-collaborative playlist-modify-private playlist-modify-public user-read-recently-played user-top-read user-read-currently-playing user-read-playback-state user-modify-playback-state streaming"

# ─── Local OAuth callback server ─────────────────────────
OAUTH_CALLBACK_HOST=127.0.0.1
OAUTH_CALLBACK_PORT=8080
OAUTH_PUBLIC_HOST=mrms.approid.team

# ─── PostgreSQL (pgvector) ───────────────────────────────
# 로컬 docker compose가 띄움
DATABASE_URL=postgresql://mrms:mrms@localhost:5432/mrms

# ─── Storage Paths (외장 SSD = 프로젝트 루트와 동일) ──────
PROJECT_ROOT=/Volumes/MacExtend 1/MRMS_FN
DATA_ROOT=${PROJECT_ROOT}/data
AUDIO_DIR=${DATA_ROOT}/audio
MEL_DIR=${DATA_ROOT}/mel
EMBED_DIR=${DATA_ROOT}/embeddings
CHECKPOINT_DIR=${PROJECT_ROOT}/checkpoints
LOG_DIR=${PROJECT_ROOT}/logs

# ─── Model Config ────────────────────────────────────────
ENCODER_MODEL_ID=m-a-p/MERT-v1-95M
MODEL_VERSION=mert-v1.0
ENCODER_DEVICE=mps
ENCODER_PRECISION=fp16
EMBEDDING_DIM=256
BATCH_SIZE=8
SAMPLE_RATE=22050
CHUNK_DURATION=30

# ─── Existing Data Paths (있으면 채워주세요) ──────────────
# 110k Tidal/Spotify audio features를 가진 트랙 (CSV/Parquet)
TRACKS_110K_PATH=
# 90k 일반 정보 트랙 (CSV/Parquet) — 다운로드 대상
TRACKS_90K_PATH=

# ─── Download Config ─────────────────────────────────────
DOWNLOAD_CONCURRENCY=20
DOWNLOAD_PREVIEW_SECONDS=30
DOWNLOAD_FORMAT=mp3

# E.0+1+2 Web Viewer
DEFAULT_USER_EMAIL=
